generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String?
  role      String   @default("OWNER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id                 String      @id @default(uuid())
  name               String
  type               ContactType
  contactPerson      String?
  phone              String?     @unique
  altPhone           String?
  email              String?     @unique
  gstNumber          String?
  address            String?
  city               String?
  state              String?
  pincode            String?
  openingBalance     Decimal     @default(0.0) @db.Decimal(12, 2)
  notes              String?
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  payments           Payment[]
  purchases          Purchase[]
  sales              Sale[]

  @@index([type])
}

model Product {
  id                String               @id @default(uuid())
  code              String               @unique
  name              String               @unique
  type              ProductType
  description       String?
  imageUrl          String?
  volumeMl          String?
  color             String?
  currentStock      Decimal              @default(0.0) @db.Decimal(12, 2)
  averageCost       Decimal              @default(0.0) @db.Decimal(12, 2)
  purchasePrice     Decimal?             @db.Decimal(12, 2)
  sellingPrice      Decimal?             @db.Decimal(12, 2)
  minStockAlert     Decimal?             @db.Decimal(12, 2)
  isActive          Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  categoryId        String?
  unitId            String?
  bomItems          BOMItem[]
  bomRecipes        BOMRecipe[]
  saleItems         SaleItem[]
  category          ProductCategory?     @relation(fields: [categoryId], references: [id])
  unit              Unit?                @relation(fields: [unitId], references: [id])
  productionBatches ProductionBatch[]
  consumedInBatches ProductionMaterial[]
  purchaseItems     PurchaseItem[]
  stockMovements    StockMovement[]

  @@index([type])
  @@index([categoryId])
  @@index([unitId])
}

model ProductCategory {
  id        String    @id @default(uuid())
  name      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Unit {
  id            String         @id @default(uuid())
  name          String         @unique
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  products      Product[]
  purchaseItems PurchaseItem[]
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BOMRecipe {
  id                 String            @id @default(uuid())
  name               String            @unique
  finishedProductId  String
  wasteFactorPercent Decimal           @default(0.0) @db.Decimal(5, 2)
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  items              BOMItem[]
  finishedProduct    Product           @relation(fields: [finishedProductId], references: [id])
  productionBatches  ProductionBatch[]

  @@index([finishedProductId])
}

model BOMItem {
  id         String    @id @default(uuid())
  recipeId   String
  materialId String
  quantity   Decimal   @db.Decimal(12, 4)
  material   Product   @relation(fields: [materialId], references: [id])
  recipe     BOMRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, materialId])
  @@index([materialId])
}

model StockMovement {
  id          String       @id @default(uuid())
  productId   String
  quantity    Decimal      @db.Decimal(12, 2)
  type        MovementType
  referenceId String?
  notes       String?
  createdAt   DateTime     @default(now())
  product     Product      @relation(fields: [productId], references: [id])

  @@index([productId, createdAt])
}

model Sale {
  id               String            @id @default(uuid())
  saleNumber       String            @unique
  customerId       String
  saleDate         DateTime          @default(now())
  reference        String?
  notes            String?
  discount         Decimal           @default(0.0) @db.Decimal(12, 2)
  transportCharges Decimal           @default(0.0) @db.Decimal(12, 2)
  subtotal         Decimal           @db.Decimal(12, 2)
  grandTotal       Decimal           @db.Decimal(12, 2)
  status           SaleStatus        @default(COMPLETED)
  paymentStatus    SalePaymentStatus @default(UNPAID)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  customer         Contact           @relation(fields: [customerId], references: [id])
  items            SaleItem[]
  payments         Payment[]

  @@index([customerId])
  @@index([saleNumber])
}

model SaleItem {
  id          String   @id @default(uuid())
  saleId      String
  productId   String
  quantity    Decimal  @db.Decimal(12, 2)
  sellingRate Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0.0) @db.Decimal(12, 2)
  lineTotal   Decimal  @db.Decimal(12, 2)
  remarks     String?
  product     Product  @relation(fields: [productId], references: [id])
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
}

model Payment {
  id              String        @id @default(uuid())
  contactId       String
  paymentType     PaymentType
  amount          Decimal       @db.Decimal(12, 2)
  paymentDate     DateTime      @default(now())
  paymentMethod   PaymentMethod
  referenceNumber String?
  purchaseId      String?
  saleId          String?
  notes           String?
  createdAt       DateTime      @default(now())
  contact         Contact       @relation(fields: [contactId], references: [id])
  purchase        Purchase?     @relation(fields: [purchaseId], references: [id])
  sale            Sale?         @relation(fields: [saleId], references: [id])

  @@index([contactId])
  @@index([purchaseId])
  @@index([saleId])
}

model ProductionBatch {
  id                String               @id @default(uuid())
  batchNumber       String               @unique
  recipeId          String
  productId         String
  quantityProduced  Decimal              @db.Decimal(12, 2)
  batchDate         DateTime             @default(now())
  fuelCost          Decimal              @default(0.0) @db.Decimal(12, 2)
  labourCost        Decimal              @default(0.0) @db.Decimal(12, 2)
  packingCost       Decimal              @default(0.0) @db.Decimal(12, 2)
  transportCost     Decimal              @default(0.0) @db.Decimal(12, 2)
  electricityCost   Decimal              @default(0.0) @db.Decimal(12, 2)
  maintenanceCost   Decimal              @default(0.0) @db.Decimal(12, 2)
  miscCost          Decimal              @default(0.0) @db.Decimal(12, 2)
  totalMaterialCost Decimal              @default(0.0) @db.Decimal(12, 2)
  totalBatchCost    Decimal              @default(0.0) @db.Decimal(12, 2)
  unitCost          Decimal              @default(0.0) @db.Decimal(12, 2)
  status            BatchStatus          @default(DRAFT)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  product           Product              @relation(fields: [productId], references: [id])
  recipe            BOMRecipe            @relation(fields: [recipeId], references: [id])
  materialsConsumed ProductionMaterial[]

  @@index([productId])
  @@index([recipeId])
  @@index([batchNumber])
}

model ProductionMaterial {
  id               String          @id @default(uuid())
  batchId          String
  materialId       String
  quantityConsumed Decimal         @db.Decimal(12, 4)
  unitCost         Decimal         @db.Decimal(12, 2)
  batch            ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  material         Product         @relation(fields: [materialId], references: [id])

  @@index([batchId])
  @@index([materialId])
}

model Purchase {
  id                    String                @id @default(uuid())
  purchaseNumber        String                @unique
  supplierId            String
  purchaseDate          DateTime              @default(now())
  supplierInvoiceNumber String?
  reference             String?
  notes                 String?
  discount              Decimal               @default(0.0) @db.Decimal(12, 2)
  transportCharges      Decimal               @default(0.0) @db.Decimal(12, 2)
  subtotal              Decimal               @db.Decimal(12, 2)
  grandTotal            Decimal               @db.Decimal(12, 2)
  status                PurchaseStatus        @default(COMPLETED)
  paymentStatus         PurchasePaymentStatus @default(UNPAID)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  supplier              Contact               @relation(fields: [supplierId], references: [id])
  items                 PurchaseItem[]
  payments              Payment[]

  @@index([supplierId])
  @@index([purchaseNumber])
}

model PurchaseItem {
  id           String   @id @default(uuid())
  purchaseId   String
  productId    String
  quantity     Decimal  @db.Decimal(12, 2)
  unitId       String
  purchaseRate Decimal  @db.Decimal(12, 2)
  discount     Decimal  @default(0.0) @db.Decimal(12, 2)
  lineTotal    Decimal  @db.Decimal(12, 2)
  remarks      String?
  product      Product  @relation(fields: [productId], references: [id])
  purchase     Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  unit         Unit     @relation(fields: [unitId], references: [id])

  @@index([purchaseId])
  @@index([productId])
  @@index([unitId])
}

enum ContactType {
  CUSTOMER
  SUPPLIER
}

enum ProductType {
  RAW_MATERIAL
  FINISHED_GOOD
  TRADING_PRODUCT
}

enum MovementType {
  PURCHASE
  SALE
  PRODUCTION_CONSUMPTION
  PRODUCTION_OUTPUT
  ADJUSTMENT
}

enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum SalePaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum PaymentType {
  CUSTOMER_RECEIPT
  SUPPLIER_PAYMENT
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  UPI
}

enum BatchStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum PurchaseStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum PurchasePaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}
