generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
}

model Profile {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String?
  role      String   @default("OWNER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id                 String      @id @default(uuid())
  name               String
  type               ContactType
  contactPerson      String?
  phone              String?     @unique
  altPhone           String?
  email              String?     @unique
  gstNumber          String?
  address            String?
  city               String?
  state              String?
  pincode            String?
  openingBalance     Decimal     @default(0.0) @db.Decimal(12, 2)
  notes              String?
  creditLimit        Decimal?    @db.Decimal(12, 2)
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  payments           Payment[]
  purchases          Purchase[]
  sales              Sale[]

  @@index([type])
}

model Product {
  id                String               @id @default(uuid())
  code              String               @unique
  name              String               @unique
  type              ProductType
  description       String?
  imageUrl          String?
  volumeMl          String?
  color             String?
  currentStock      Decimal              @default(0.0) @db.Decimal(12, 2)
  averageCost       Decimal              @default(0.0) @db.Decimal(12, 2)
  purchasePrice     Decimal?             @db.Decimal(12, 2)
  sellingPrice      Decimal?             @db.Decimal(12, 2)
  minStockAlert     Decimal?             @db.Decimal(12, 2)
  hsnCode           String?
  gstRate           Decimal?             @db.Decimal(5, 2)
  isActive          Boolean              @default(true)
  piecesPerBox      Int?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  categoryId        String?
  unitId            String?
  saleItems         SaleItem[]
  category          ProductCategory?     @relation(fields: [categoryId], references: [id])
  unit              Unit?                @relation(fields: [unitId], references: [id])
  productionEntries ProductionEntry[]
  purchaseItems     PurchaseItem[]
  stockMovements    StockMovement[]

  @@index([type])
  @@index([categoryId])
  @@index([unitId])
}

model ProductCategory {
  id        String    @id @default(uuid())
  name      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Unit {
  id            String         @id @default(uuid())
  name          String         @unique
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  products      Product[]
  purchaseItems PurchaseItem[]
}

model ExpenseCategory {
  id                    String                 @id @default(uuid())
  name                  String                 @unique
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  manufacturingExpenses ManufacturingExpense[]
}

model ManufacturingExpense {
  id            String          @id @default(uuid())
  expenseNumber String          @unique
  categoryId    String
  description   String
  amount        Decimal         @db.Decimal(12, 2)
  notes         String?
  expenseDate   DateTime        @default(now())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  category      ExpenseCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([expenseDate])
}

model ProductionEntry {
  id               String   @id @default(uuid())
  productionNumber String   @unique
  productId        String
  boxesProduced    Decimal  @db.Decimal(12, 2)
  piecesPerBox     Int
  totalPieces      Decimal  @db.Decimal(12, 2)
  productionDate   DateTime @default(now())
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  product          Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([productionDate])
}

model StockMovement {
  id          String       @id @default(uuid())
  productId   String
  quantity    Decimal      @db.Decimal(12, 2)
  type        MovementType
  referenceId String?
  notes       String?
  createdAt   DateTime     @default(now())
  product     Product      @relation(fields: [productId], references: [id])

  @@index([productId, createdAt])
}

model Sale {
  id               String            @id @default(uuid())
  saleNumber       String            @unique
  customerId       String
  saleDate         DateTime          @default(now())
  reference        String?
  notes            String?
  discount         Decimal           @default(0.0) @db.Decimal(12, 2)
  transportCharges Decimal           @default(0.0) @db.Decimal(12, 2)
  subtotal         Decimal           @db.Decimal(12, 2)
  grandTotal       Decimal           @db.Decimal(12, 2)
  status           SaleStatus        @default(COMPLETED)
  paymentStatus    SalePaymentStatus @default(UNPAID)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  customer         Contact           @relation(fields: [customerId], references: [id])
  items            SaleItem[]
  payments         Payment[]

  @@index([customerId])
  @@index([saleNumber])
}

model SaleItem {
  id          String   @id @default(uuid())
  saleId      String
  productId   String
  quantity    Decimal  @db.Decimal(12, 2)
  sellingRate Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0.0) @db.Decimal(12, 2)
  lineTotal   Decimal  @db.Decimal(12, 2)
  remarks     String?
  product     Product  @relation(fields: [productId], references: [id])
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
}

model Payment {
  id                 String        @id @default(uuid())
  paymentNumber      String        @unique
  contactId          String
  paymentType        PaymentType
  amount             Decimal       @db.Decimal(12, 2)
  paymentDate        DateTime      @default(now())
  paymentMethod      PaymentMethod
  referenceNumber    String?
  notes              String?
  status             PaymentStatus @default(COMPLETED)
  cancellationReason String?
  isAdvance          Boolean       @default(false)
  createdById        String?
  updatedById        String?
  purchaseId         String?
  saleId             String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  contact            Contact       @relation(fields: [contactId], references: [id])
  purchase           Purchase?     @relation(fields: [purchaseId], references: [id])
  sale               Sale?         @relation(fields: [saleId], references: [id])

  @@index([contactId])
  @@index([purchaseId])
  @@index([saleId])
}

model Purchase {
  id                    String                @id @default(uuid())
  purchaseNumber        String                @unique
  supplierId            String
  purchaseDate          DateTime              @default(now())
  supplierInvoiceNumber String?
  reference             String?
  notes                 String?
  discount              Decimal               @default(0.0) @db.Decimal(12, 2)
  transportCharges      Decimal               @default(0.0) @db.Decimal(12, 2)
  subtotal              Decimal               @db.Decimal(12, 2)
  grandTotal            Decimal               @db.Decimal(12, 2)
  status                PurchaseStatus        @default(COMPLETED)
  paymentStatus         PurchasePaymentStatus @default(UNPAID)
  receivedQuantity      Decimal?              @db.Decimal(12, 2)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  supplier              Contact               @relation(fields: [supplierId], references: [id])
  items                 PurchaseItem[]
  payments              Payment[]

  @@index([supplierId])
  @@index([purchaseNumber])
}

model PurchaseItem {
  id           String   @id @default(uuid())
  purchaseId   String
  productId    String
  quantity     Decimal  @db.Decimal(12, 2)
  unitId       String
  purchaseRate Decimal  @db.Decimal(12, 2)
  discount     Decimal  @default(0.0) @db.Decimal(12, 2)
  lineTotal    Decimal  @db.Decimal(12, 2)
  remarks      String?
  product      Product  @relation(fields: [productId], references: [id])
  purchase     Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  unit         Unit     @relation(fields: [unitId], references: [id])

  @@index([purchaseId])
  @@index([productId])
  @@index([unitId])
}

enum ContactType {
  CUSTOMER
  SUPPLIER
}

enum ProductType {
  RAW_MATERIAL
  FINISHED_GOOD
  TRADING_PRODUCT
}

enum MovementType {
  PURCHASE
  SALE
  PRODUCTION_CONSUMPTION
  PRODUCTION_OUTPUT
  ADJUSTMENT
}

enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum SalePaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum PaymentType {
  CUSTOMER_RECEIPT
  SUPPLIER_PAYMENT
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  UPI
  CHEQUE
}

enum PaymentStatus {
  COMPLETED
  CANCELLED
}

enum BatchStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum PurchaseStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum PurchasePaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}
